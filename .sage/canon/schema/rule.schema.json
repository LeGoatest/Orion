{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "statement": { "type": "string" },
    "operator": { "enum": ["MUST", "MUST_NOT", "SHOULD", "MAY"] },
    "context": { "type": "string" },
    "severity": { "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
    "enforcement": { "type": "string" },
    "source": { "type": "string" }
  },
  "required": ["id", "statement", "operator", "severity"]
}
