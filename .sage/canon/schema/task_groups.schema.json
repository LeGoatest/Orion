{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "task_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": { "type": "string" },
          "skills_allowed": { "type": "boolean" },
          "modes_allowed": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id"]
      },
      "uniqueItems": true
    }
  },
  "required": ["task_groups"]
}
